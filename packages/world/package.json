{
  "name": "@worlddesc/world",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "bin": {
    "worlddesc": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare:schemas": "node ../../scripts/sync-package-schemas.mjs",
    "build": "npm run prepare:schemas && tsc -b",
    "checkasset": "node ./dist/checkAsset.js",
    "typecheck": "tsc -b --pretty false",
    "checkworld": "node ./dist/checkWorld.js",
    "cli": "node ./dist/cli.js",
    "prepack": "npm run prepare:schemas",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
